<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/widgetRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_widget_container"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvWidgetTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/widget_title"
            android:textColor="@color/widget_text_primary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvWidgetBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_widget_badge"
            android:paddingStart="10dp"
            android:paddingTop="5dp"
            android:paddingEnd="10dp"
            android:paddingBottom="5dp"
            android:text="@string/widget_off"
            android:textColor="@color/widget_text_secondary"
            android:textSize="9sp"
            android:textStyle="bold"
            tools:ignore="SmallSp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:baselineAligned="false"
            android:orientation="horizontal"
            android:weightSum="2">

            <LinearLayout
                android:id="@+id/btnWidgetOff"
                android:layout_width="0dp"
                android:layout_height="68dp"
                android:layout_weight="1"
                android:background="@drawable/bg_widget_button"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="8dp">

                <ImageView
                    android:id="@+id/ivWidgetOff"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:contentDescription="@string/label_off"
                    android:src="@drawable/ic_widget_off" />

                <TextView
                    android:id="@+id/tvWidgetOff"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:text="@string/widget_off"
                    android:textColor="@color/widget_text_primary"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    tools:ignore="SmallSp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnWidgetMin"
                android:layout_width="0dp"
                android:layout_height="68dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_widget_button"
                android:baselineAligned="false"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="8dp">

                <ImageView
                    android:id="@+id/ivWidgetMin"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:contentDescription="@string/minimum"
                    android:src="@drawable/ic_widget_min" />

                <TextView
                    android:id="@+id/tvWidgetMin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:baselineAligned="false"
                    android:text="@string/widget_min"
                    android:textColor="@color/widget_text_primary"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    tools:ignore="SmallSp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:weightSum="2"
            tools:ignore="DisableBaselineAlignment">

            <LinearLayout
                android:id="@+id/btnWidgetAdaptive"
                android:layout_width="0dp"
                android:layout_height="68dp"
                android:layout_weight="1"
                android:background="@drawable/bg_widget_button"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="8dp">

                <ImageView
                    android:id="@+id/ivWidgetAdaptive"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:contentDescription="@string/mode_adaptive"
                    android:src="@drawable/ic_widget_adaptive" />

                <TextView
                    android:id="@+id/tvWidgetAdaptive"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:text="@string/widget_adaptive"
                    android:textColor="@color/widget_text_primary"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    tools:ignore="SmallSp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnWidgetMax"
                android:layout_width="0dp"
                android:layout_height="68dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_widget_button"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="8dp">

                <ImageView
                    android:id="@+id/ivWidgetMax"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:contentDescription="@string/maximum"
                    android:src="@drawable/ic_widget_max" />

                <TextView
                    android:id="@+id/tvWidgetMax"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:text="@string/widget_max"
                    android:textColor="@color/widget_text_primary"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    tools:ignore="SmallSp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>